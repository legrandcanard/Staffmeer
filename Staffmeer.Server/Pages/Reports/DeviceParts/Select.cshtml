@page
@using Microsoft.EntityFrameworkCore
@using Staffmeer.Server.Models.Contexts
@inject ApplicationDbContext context

@{
	var title = "Комплектующие устройства (номенклатуры)";
	ViewData["Title"] = title;

	var items = context.Nomenclatures.Include(n => n.Brandname).Select(e => new { e.Id, Text = e.FullName }).ToList();
	items.Insert(0, new { Id = 0, Text = "(не выбрано)" });
	var list = new SelectList(items, "Id", "Text");
}

<h3>Отчёт</h3>
<h4>@title</h4>
<hr />
<div class="form-group">
	<label class="control-label">Номенклатура</label>
	<select id="options-list" class="form-control" asp-items="list" autocomplete="off"></select>
</div>
<a id="btnCreateReport" class="btn btn-outline-primary mt-3 disabled" role="button" asp-page="Index" asp-route-id="0"><span class="mdi mdi-file-document-outline"></span> Сформировать</a>

@section Scripts {
	<script src="~/js/reports.js" type="text/javascript"></script>
}