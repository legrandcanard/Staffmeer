@page
@using Staffmeer.Server.Pages.Shared
@model Staffmeer.Server.Pages.Employees.EditModel

@{
    ViewData["Title"] = Model.Employee.FullName;
}

@await Html.PartialAsync("_ViewNavHeader", new ViewNavHeaderModel("Редактирование", "./Details", Model.Employee.Id))

<h4>Данные</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Employee.Id" />
            <div class="form-group">
                <label asp-for="Employee.FirstName" class="control-label"></label>
                <input asp-for="Employee.FirstName" class="form-control" />
                <span asp-validation-for="Employee.FirstName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Employee.LastName" class="control-label"></label>
                <input asp-for="Employee.LastName" class="form-control" />
                <span asp-validation-for="Employee.LastName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Employee.Patronymic" class="control-label"></label>
                <input asp-for="Employee.Patronymic" class="form-control" />
                <span asp-validation-for="Employee.Patronymic" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Employee.DepartmentId" class="control-label"></label>
                <select asp-for="Employee.DepartmentId" class="form-control" asp-items="ViewBag.DepartmentId"></select>
                <span asp-validation-for="Employee.DepartmentId" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <button type="submit" class="btn btn-outline-primary">
                    <span class="mdi mdi-content-save"></span>
                    Сохранить
                </button>
                <a class="btn btn-outline-primary" role="button" asp-page="./Delete" asp-route-id="@Model.Employee.Id"><span class="mdi mdi-account-remove"></span> Удалить</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
