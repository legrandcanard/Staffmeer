@page
@model Staffmeer.Server.Pages.Counterparties.EditModel

@{
    ViewData["Title"] = Model.Counterparty.Name;
}

@await Html.PartialAsync("_ViewNavHeader", new ViewNavHeaderModel(TextConstants.Edit, "Details", Model.Counterparty.Id))

<h4>Данные</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Counterparty.Id" />
            <div class="form-group">
                <label asp-for="Counterparty.Name" class="control-label"></label>
                <input asp-for="Counterparty.Name" class="form-control" />
                <span asp-validation-for="Counterparty.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Counterparty.PhoneNumber" class="control-label"></label>
                <input asp-for="Counterparty.PhoneNumber" class="form-control" />
                <span asp-validation-for="Counterparty.PhoneNumber" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Counterparty.Address" class="control-label"></label>
                <input asp-for="Counterparty.Address" class="form-control" />
                <span asp-validation-for="Counterparty.Address" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                @await Html.PartialAsync("_FormUpdateButton")
                @await Html.PartialAsync("_FormLinkToDelete", Model.Counterparty.Id)
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
