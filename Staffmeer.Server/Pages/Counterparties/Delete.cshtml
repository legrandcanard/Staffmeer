@page
@model Staffmeer.Server.Pages.Counterparties.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

@await Html.PartialAsync("_ViewNavHeader", new ViewNavHeaderModel(TextConstants.Delete, "Edit", Model.Counterparty.Id))

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Counterparty</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Counterparty.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Counterparty.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Counterparty.PhoneNumber)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Counterparty.PhoneNumber)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Counterparty.Address)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Counterparty.Address)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Counterparty.Id" />
        <button type="submit" class="btn btn-outline-danger">
            <span class="mdi mdi-delete"></span>
            Подтвердить удаление
        </button>
        <a class="btn btn-outline-primary" asp-page="./Edit" asp-route-id="@Model.Counterparty.Id">
            <span class="mdi mdi-window-close"></span>
            Отмена
        </a>
    </form>
</div>
