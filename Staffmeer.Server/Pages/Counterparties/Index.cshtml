@page
@using Staffmeer.Server.Pages.Shared
@model Staffmeer.Server.Pages.Counterparties.IndexModel

@{
    string title = "Контрагенты";
    ViewData["Title"] = title;
}

@await Html.PartialAsync("IndexHeader", new IndexHeaderModel { HeaderTitle = title })

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Counterparty[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Counterparty[0].PhoneNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Counterparty[0].Address)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Counterparty) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PhoneNumber)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Address)
            </td>
            <td>
                <a class="smr-link text-color-main" asp-page="./Details" asp-route-id="@item.Id">Детали</a>
            </td>
        </tr>
}
    </tbody>
</table>
