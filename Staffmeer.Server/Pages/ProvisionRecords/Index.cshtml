@page
@model Staffmeer.Server.Pages.ProvisionRecords.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ProvisionRecord[0].Date)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProvisionRecord[0].Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProvisionRecord[0].Counterparty)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProvisionRecord[0].Employee1)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProvisionRecord[0].Employee2)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProvisionRecord[0].Nomenclature1)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProvisionRecord[0].Nomenclature2)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProvisionRecord[0].ProvisionRecordType)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.ProvisionRecord) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Date)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Counterparty.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Employee1.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Employee2.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Nomenclature1.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Nomenclature2.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ProvisionRecordType.Id)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
