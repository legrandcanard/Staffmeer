@page
@model Staffmeer.Server.Pages.ProvisionRecords.CreateModel

@{
    ViewData["Title"] = "Create";
}

@await Html.PartialAsync("_ViewNavHeader", new ViewNavHeaderModel("Создание", "Index"))

<h4>Данные</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="ProvisionRecord.Date" class="control-label"></label>
                <input asp-for="ProvisionRecord.Date" class="form-control" />
                <span asp-validation-for="ProvisionRecord.Date" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProvisionRecord.Nomenclature1Id" class="control-label"></label>
                <select asp-for="ProvisionRecord.Nomenclature1Id" class ="form-control" asp-items="ViewBag.Nomenclature1Id"></select>
            </div>
            <div class="form-group">
                <label asp-for="ProvisionRecord.Nomenclature2Id" class="control-label"></label>
                <select asp-for="ProvisionRecord.Nomenclature2Id" class ="form-control" asp-items="ViewBag.Nomenclature2Id"></select>
            </div>
            <div class="form-group">
                <label asp-for="ProvisionRecord.Employee1Id" class="control-label"></label>
                <select asp-for="ProvisionRecord.Employee1Id" class ="form-control" asp-items="ViewBag.Employee1Id"></select>
            </div>
            <div class="form-group">
                <label asp-for="ProvisionRecord.Employee2Id" class="control-label"></label>
                <select asp-for="ProvisionRecord.Employee2Id" class ="form-control" asp-items="ViewBag.Employee2Id"></select>
            </div>
            <div class="form-group">
                <label asp-for="ProvisionRecord.CounterpartyId" class="control-label"></label>
                <select asp-for="ProvisionRecord.CounterpartyId" class ="form-control" asp-items="ViewBag.CounterpartyId"></select>
            </div>
            <div class="form-group">
                <label asp-for="ProvisionRecord.ProvisionRecordTypeId" class="control-label"></label>
                <select asp-for="ProvisionRecord.ProvisionRecordTypeId" class ="form-control" asp-items="ViewBag.ProvisionRecordTypeId"></select>
            </div>
            <div class="form-group">
                <label asp-for="ProvisionRecord.Description" class="control-label"></label>
                <input asp-for="ProvisionRecord.Description" class="form-control" />
                <span asp-validation-for="ProvisionRecord.Description" class="text-danger"></span>
            </div>
            <div class="form-group mt-2">
                <button type="submit" class="btn btn-outline-primary">
                    <span class="mdi mdi-content-save"></span>
                    Сохранить
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
